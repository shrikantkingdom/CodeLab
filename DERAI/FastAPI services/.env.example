# DERAI FastAPI Services — Environment Variables
# Copy to .env and fill in values

# --- Application ---
DEBUG=false
LOG_LEVEL=INFO

# --- Security ---
API_KEY=dev-api-key-change-me

# --- External PDF API ---
PDF_API_BASE_URL=http://localhost:9000/api/v1
PDF_API_TIMEOUT=30

# --- Spring Boot service ---
SPRINGBOOT_URL=http://localhost:8080
SPRINGBOOT_TIMEOUT=30

# --- AI / LLM ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_TEMPERATURE=0.0
AI_MAX_TOKENS=4096

# --- Snowflake (Statements) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=

# --- DB2 (Letters & Confirms) ---
DB2_HOST=
DB2_PORT=50000
DB2_DATABASE=
DB2_USER=
DB2_PASSWORD=
