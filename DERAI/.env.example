# ----- Shared -----
API_KEY=dev-api-key-change-me

# ----- FastAPI -----
PDF_API_BASE_URL=https://pdf-api.example.com
LOG_LEVEL=INFO

# AI Provider: openai | github_copilot | anthropic | google_gemini | deepseek | regex_only
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# GitHub Copilot (Models API) — use a GitHub PAT with copilot scope
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Snowflake (leave empty for mock mode)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=

# DB2 (leave empty for mock mode)
DB2_HOST=
DB2_PORT=50000
DB2_DATABASE=
DB2_USER=
DB2_PASSWORD=

# Azure Document Intelligence OCR (leave empty for mock mode)
AZURE_DOC_ENDPOINT=
AZURE_DOC_API_KEY=
AZURE_DOC_MODEL=prebuilt-read
